generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  HOMBRE
  DAMA
  UNISEX
}

enum ProductKind {
  TERNO
  SACO
  PANTALON
  CAMISA
  BLUSA
  CHALECO
  ACCESORIO
  SMOKING
  BUNDLE
}

enum ProductStatus {
  ACTIVO
  AGOTADO
  TEMPORALMENTE_NO_DISPONIBLE
  INACTIVO
}

enum StockTrackingMode {
  NONE
  VARIANT
  INDIVIDUAL
  MIXED
}

enum AttributeScope {
  PRODUCT
  VARIANT
}

enum InputFieldType {
  SELECT
  MULTISELECT
  TEXT
  TEXTAREA
  NUMBER
  BOOLEAN
  COLOR
}

enum MeasurementGarmentType {
  SACO_CABALLERO
  PANTALON_CABALLERO
  SACO_DAMA
  PANTALON_DAMA
  CAMISA
  BLUSA
  CHALECO
  FALDA
  SMOKING
}

enum FabricPriceMode {
  A_TODO_COSTO
  SOLO_CONFECCION
}

enum AppointmentType {
  TOMA_MEDIDAS
  ARREGLO
  ENTREGA
  ASESORIA
  OTRA
}

enum AppointmentStatus {
  PENDIENTE
  CONFIRMADA
  REPROGRAMADA
  CANCELADA
  NO_ASISTIO
  REALIZADA
}

enum SaleOrderStatus {
  PENDIENTE_PAGO
  PAGADO
  EN_PREPARACION
  LISTO_PARA_RECOJO
  ENTREGADO
  CANCELADO
}

enum CustomOrderStatus {
  PENDIENTE_RESERVA
  RESERVA_CONFIRMADA
  MEDIDAS_TOMADAS
  EN_CONFECCION
  EN_PRUEBA
  LISTO
  ENTREGADO
  CANCELADO
}

enum RentalOrderStatus {
  RESERVADO
  ENTREGADO
  DEVUELTO
  ATRASADO
  CERRADO
  CANCELADO
}

enum AlterationOrderStatus {
  RECIBIDO
  EN_EVALUACION
  EN_PROCESO
  LISTO
  ENTREGADO
  CANCELADO
}

enum RentalUnitStatus {
  DISPONIBLE
  ALQUILADO
  EN_MANTENIMIENTO
  DANADO
  RETIRADO
}

enum RentalPriceTier {
  ESTRENO
  NORMAL
}

enum InventoryMovementType {
  INGRESO
  AJUSTE
  VENTA
  ALQUILER
  DEVOLUCION
  MERMA
  REPARACION
}

enum PaymentMethod {
  EFECTIVO
  YAPE
  PLIN
  TRANSFERENCIA
  TARJETA
  MIXTO
  OTRO
}

enum PaymentStatus {
  PENDIENTE
  APROBADO
  OBSERVADO
  ANULADO
  DEVUELTO
}

enum PaymentConcept {
  ADELANTO
  SALDO
  PAGO_TOTAL
  RESERVA_CITA
  OTRO
}

enum VoucherProvider {
  YAPE
  PLIN
  BANCO
  OTRO
}

enum ComprobanteType {
  BOLETA
  FACTURA
  NOTA_CREDITO
  NOTA_DEBITO
  TICKET
}

enum ComprobanteStatus {
  BORRADOR
  EMITIDO
  ANULADO
}

enum PromotionScope {
  ORDEN
  PRODUCTO
  BUNDLE
}

enum DiscountType {
  PORCENTAJE
  MONTO_FIJO
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  INTERNO
}

enum NotificationStatus {
  PENDIENTE
  ENVIADA
  FALLIDA
  LEIDA
}

model AdminUser {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authUserId         String?                    @unique
  email              String                     @unique
  passwordHash       String
  nombres            String
  apellidos          String?
  isActive           Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  authUser           User?                      @relation("AdminAuthUser", fields: [authUserId], references: [id], onDelete: SetNull)
  createdStatusLogs  AppointmentStatusHistory[]
  saleStatusLogs     SaleOrderStatusHistory[]
  customStatusLogs   CustomOrderStatusHistory[]
  rentalStatusLogs   RentalOrderStatusHistory[]
  alterationLogs     AlterationOrderStatusHistory[]
  customerNotes      CustomerNote[]
}

model Customer {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authUserId          String?             @unique
  nombres             String
  apellidos           String
  email               String              @unique
  celular             String?
  dni                 String              @unique
  passwordHash        String
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  authUser            User?               @relation("CustomerAuthUser", fields: [authUserId], references: [id], onDelete: SetNull)
  notes               CustomerNote[]
  files               CustomerFile[]
  measurementProfiles MeasurementProfile[]
  appointments        Appointment[]
  saleOrders          SaleOrder[]
  customOrders        CustomOrder[]
  rentalOrders        RentalOrder[]
  alterationOrders    AlterationOrder[]
  payments            Payment[]
  comprobantes        Comprobante[]
  notifications       Notification[]
}

model CustomerNote {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  adminUserId String? @db.Uuid
  note        String
  createdAt   DateTime   @default(now())

  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
}

model CustomerFile {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  fileName    String
  fileUrl     String
  mimeType    String?
  description String?
  createdAt   DateTime  @default(now())

  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Brand {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre    String    @unique
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Product {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre                   String
  slug                     String                     @unique
  descripcion              String?
  kind                     ProductKind
  gender                   Gender?
  status                   ProductStatus              @default(ACTIVO)
  stockTrackingMode        StockTrackingMode          @default(VARIANT)
  requiresMeasurement      Boolean                    @default(false)
  allowsSale               Boolean                    @default(true)
  allowsRental             Boolean                    @default(false)
  allowsCustomization      Boolean                    @default(false)
  isFeatured               Boolean                    @default(false)
  isNew                    Boolean                    @default(false)
  active                   Boolean                    @default(true)
  brandId String? @db.Uuid
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  brand                    Brand?                     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  images                   ProductImage[]
  variants                 ProductVariant[]
  attributeValues          ProductAttributeValue[]
  rentalUnits              RentalUnit[]
  saleItems                SaleOrderItem[]
  saleComponentItems       SaleOrderItemComponent[]
  customItems              CustomOrderItem[]
  customParts              CustomOrderItemPart[]
  rentalItems              RentalOrderItem[]
  bundleItems              BundleItem[]
  customizationDefinitions CustomizationDefinition[]
  parentComponents         ProductComponent[]         @relation("ProductComponentParent")
  childComponents          ProductComponent[]         @relation("ProductComponentChild")
  promotionTargets         PromotionProductTarget[]
}

model ProductImage {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String @db.Uuid
  url        String
  altText    String?
  sortOrder  Int      @default(0)

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String @db.Uuid
  sku                String                @unique
  talla              String?
  tallaSecundaria    String?
  color              String?
  colorCodigo        String?
  stock              Int                   @default(0)
  minStock           Int                   @default(0)
  salePrice          Decimal               @db.Decimal(10, 2)
  compareAtPrice     Decimal?              @db.Decimal(10, 2)
  active             Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  product            Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues    VariantAttributeValue[]
  stockMovements     ProductStockMovement[]
  saleOrderItems     SaleOrderItemComponent[]
  rentalUnits        RentalUnit[]
  images             ProductVariantImage[]
  bundleVariantItems BundleVariantItem[]
}

model ProductVariantImage {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId String @db.Uuid
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, sortOrder])
}

model CatalogAttributeDefinition {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String
  label          String
  scope          AttributeScope
  inputType      InputFieldType
  appliesToKind  ProductKind?
  active         Boolean                  @default(true)
  sortOrder      Int                      @default(0)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  options        CatalogAttributeOption[]
  productValues  ProductAttributeValue[]
  variantValues  VariantAttributeValue[]

  @@unique([code, scope])
}

model CatalogAttributeOption {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  definitionId String @db.Uuid
  code          String
  label         String
  sortOrder     Int                        @default(0)
  active        Boolean                    @default(true)

  definition    CatalogAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  productValues ProductAttributeValue[]
  variantValues VariantAttributeValue[]

  @@unique([definitionId, code])
}

model ProductAttributeValue {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String @db.Uuid
  definitionId String @db.Uuid
  optionId String? @db.Uuid
  valueText     String?
  valueNumber   Decimal?                   @db.Decimal(10, 2)
  valueBoolean  Boolean?

  product       Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  definition    CatalogAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  option        CatalogAttributeOption?    @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([productId, definitionId])
}

model VariantAttributeValue {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId String @db.Uuid
  definitionId String @db.Uuid
  optionId String? @db.Uuid
  valueText     String?
  valueNumber   Decimal?                   @db.Decimal(10, 2)
  valueBoolean  Boolean?

  variant       ProductVariant             @relation(fields: [variantId], references: [id], onDelete: Cascade)
  definition    CatalogAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  option        CatalogAttributeOption?    @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([variantId, definitionId])
}

model ProductComponent {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentProductId String @db.Uuid
  childProductId String @db.Uuid
  quantity         Int      @default(1)
  sortOrder        Int      @default(0)

  parentProduct    Product  @relation("ProductComponentParent", fields: [parentProductId], references: [id], onDelete: Cascade)
  childProduct     Product  @relation("ProductComponentChild", fields: [childProductId], references: [id], onDelete: Restrict)

  @@unique([parentProductId, childProductId])
}

model Bundle {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String
  slug           String          @unique
  descripcion    String?
  price          Decimal         @db.Decimal(10, 2)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items          BundleItem[]
  variantItems   BundleVariantItem[]
  saleOrderItems SaleOrderItem[]
  coupons        Coupon[]
}

model BundleItem {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bundleId String @db.Uuid
  productId String @db.Uuid
  quantity   Int      @default(1)
  sortOrder  Int      @default(0)

  bundle     Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([bundleId, productId])
}

model BundleVariantItem {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bundleId String @db.Uuid
  variantId String @db.Uuid
  quantity   Int            @default(1)
  sortOrder  Int            @default(0)

  bundle     Bundle         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([bundleId, variantId])
}

model MeasurementField {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  garmentType  MeasurementGarmentType
  code         String
  label        String
  unit         String?
  sortOrder    Int                    @default(0)
  active       Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  values       MeasurementValue[]

  @@unique([garmentType, code])
}

model MeasurementProfile {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  takenAt       DateTime             @default(now())
  validUntil    DateTime
  notes         String?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  garments      MeasurementProfileGarment[]
  customParts   CustomOrderItemPart[]
}

model MeasurementProfileGarment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId String @db.Uuid
  garmentType       MeasurementGarmentType
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  profile           MeasurementProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  values            MeasurementValue[]
  customOrderParts  CustomOrderItemPart[]

  @@unique([profileId, garmentType])
}

model MeasurementValue {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  garmentId String @db.Uuid
  fieldId String @db.Uuid
  valueNumber  Decimal?                @db.Decimal(10, 2)
  valueText    String?

  garment      MeasurementProfileGarment @relation(fields: [garmentId], references: [id], onDelete: Cascade)
  field        MeasurementField          @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@unique([garmentId, fieldId])
}

model CustomizationDefinition {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String                 @unique
  label          String
  garmentType    MeasurementGarmentType
  inputType      InputFieldType
  allowFreeText  Boolean                @default(false)
  isRequired     Boolean                @default(false)
  sortOrder      Int                    @default(0)
  active         Boolean                @default(true)
  productId String? @db.Uuid
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  product        Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  options        CustomizationOption[]
  selections     CustomOrderItemPartSelection[]
}

model CustomizationOption {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  definitionId String @db.Uuid
  code           String
  label          String
  extraPrice     Decimal?               @db.Decimal(10, 2)
  sortOrder      Int                    @default(0)
  active         Boolean                @default(true)

  definition     CustomizationDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  selections     CustomOrderItemPartSelection[]

  @@unique([definitionId, code])
}

model Fabric {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String               @unique
  nombre         String
  color          String?
  supplier       String?
  composition    String?
  pattern        String?
  metersInStock  Decimal              @db.Decimal(10, 2) @default(0)
  minMeters      Decimal              @db.Decimal(10, 2) @default(0)
  costPerMeter   Decimal?             @db.Decimal(10, 2)
  pricePerMeter  Decimal?             @db.Decimal(10, 2)
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  movements      FabricMovement[]
  customParts    CustomOrderItemPart[]
}

model FabricMovement {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fabricId String @db.Uuid
  type         InventoryMovementType
  quantity     Decimal               @db.Decimal(10, 2)
  note         String?
  happenedAt   DateTime              @default(now())

  fabric       Fabric                @relation(fields: [fabricId], references: [id], onDelete: Cascade)
}

model SaleOrder {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  code            String              @unique
  status          SaleOrderStatus     @default(PENDIENTE_PAGO)
  subtotal        Decimal             @db.Decimal(10, 2) @default(0)
  discountTotal   Decimal             @db.Decimal(10, 2) @default(0)
  total           Decimal             @db.Decimal(10, 2) @default(0)
  notes           String?
  requestedAt     DateTime            @default(now())
  preparedAt      DateTime?
  readyAt         DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  customer        Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items           SaleOrderItem[]
  payments        Payment[]
  comprobantes    Comprobante[]
  appointments    Appointment[]
  history         SaleOrderStatusHistory[]
  couponsUsed     OrderCouponUse[]
}

model SaleOrderItem {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleOrderId String @db.Uuid
  productId String? @db.Uuid
  bundleId String? @db.Uuid
  itemNameSnapshot String
  quantity         Int          @default(1)
  unitPrice        Decimal      @db.Decimal(10, 2)
  discountAmount   Decimal      @db.Decimal(10, 2) @default(0)
  subtotal         Decimal      @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  saleOrder        SaleOrder    @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  product          Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  bundle           Bundle?      @relation(fields: [bundleId], references: [id], onDelete: SetNull)
  components       SaleOrderItemComponent[]
}

model SaleOrderItemComponent {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleOrderItemId String @db.Uuid
  productId String? @db.Uuid
  variantId String? @db.Uuid
  quantity         Int             @default(1)

  saleOrderItem    SaleOrderItem   @relation(fields: [saleOrderItemId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model CustomOrder {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  code                     String             @unique
  status                   CustomOrderStatus  @default(PENDIENTE_RESERVA)
  requiresMeasurement      Boolean            @default(true)
  measurementRequiredUntil DateTime?
  firstPurchaseFlow        Boolean            @default(false)
  subtotal                 Decimal            @db.Decimal(10, 2) @default(0)
  discountTotal            Decimal            @db.Decimal(10, 2) @default(0)
  total                    Decimal            @db.Decimal(10, 2) @default(0)
  requestedDeliveryAt      DateTime?
  promisedDeliveryAt       DateTime?
  deliveredAt              DateTime?
  notes                    String?
  internalNotes            String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  customer                 Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items                    CustomOrderItem[]
  appointments             Appointment[]
  payments                 Payment[]
  comprobantes             Comprobante[]
  history                  CustomOrderStatusHistory[]
  couponsUsed              OrderCouponUse[]
}

model CustomOrderItem {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customOrderId String @db.Uuid
  productId String? @db.Uuid
  itemNameSnapshot String
  quantity         Int                  @default(1)
  unitPrice        Decimal              @db.Decimal(10, 2)
  discountAmount   Decimal              @db.Decimal(10, 2) @default(0)
  subtotal         Decimal              @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  customOrder      CustomOrder          @relation(fields: [customOrderId], references: [id], onDelete: Cascade)
  product          Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  parts            CustomOrderItemPart[]
}

model CustomOrderItemPart {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customOrderItemId String @db.Uuid
  productId String? @db.Uuid
  garmentType                 MeasurementGarmentType
  label                       String
  workMode                    FabricPriceMode        @default(A_TODO_COSTO)
  measurementProfileId String? @db.Uuid
  measurementProfileGarmentId String? @db.Uuid
  fabricId String? @db.Uuid
  fabricNameSnapshot          String?
  fabricCodeSnapshot          String?
  fabricColorSnapshot         String?
  unitPrice                   Decimal?               @db.Decimal(10, 2)
  notes                       String?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt

  customOrderItem             CustomOrderItem        @relation(fields: [customOrderItemId], references: [id], onDelete: Cascade)
  product                     Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  measurementProfile          MeasurementProfile?    @relation(fields: [measurementProfileId], references: [id], onDelete: SetNull)
  measurementProfileGarment   MeasurementProfileGarment? @relation(fields: [measurementProfileGarmentId], references: [id], onDelete: SetNull)
  fabric                      Fabric?                @relation(fields: [fabricId], references: [id], onDelete: SetNull)
  selections                  CustomOrderItemPartSelection[]
}

model CustomOrderItemPartSelection {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customOrderItemPartId String @db.Uuid
  definitionId String @db.Uuid
  optionId String? @db.Uuid
  definitionCodeSnapshot  String
  definitionLabelSnapshot String
  inputTypeSnapshot       InputFieldType
  optionCodeSnapshot      String?
  optionLabelSnapshot     String?
  extraPriceSnapshot      Decimal?               @db.Decimal(10, 2)
  valueText               String?
  valueNumber             Decimal?               @db.Decimal(10, 2)
  valueBoolean            Boolean?

  customOrderItemPart     CustomOrderItemPart    @relation(fields: [customOrderItemPartId], references: [id], onDelete: Cascade)
  definition              CustomizationDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  option                  CustomizationOption?   @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([customOrderItemPartId, definitionId])
}

model RentalUnit {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String @db.Uuid
  variantId String? @db.Uuid
  internalCode   String            @unique
  sizeLabel      String?
  color          String?
  currentTier    RentalPriceTier   @default(ESTRENO)
  normalPrice    Decimal           @db.Decimal(10, 2)
  premierePrice  Decimal           @db.Decimal(10, 2)
  status         RentalUnitStatus  @default(DISPONIBLE)
  notes          String?
  firstRentedAt  DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  product        Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant        ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)
  movements      RentalUnitMovement[]
  rentalItems    RentalOrderItem[]
}

model RentalUnitMovement {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rentalUnitId String @db.Uuid
  type         InventoryMovementType
  note         String?
  happenedAt   DateTime             @default(now())

  rentalUnit   RentalUnit           @relation(fields: [rentalUnitId], references: [id], onDelete: Cascade)
}

model RentalOrder {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  code          String             @unique
  status        RentalOrderStatus  @default(RESERVADO)
  subtotal      Decimal            @db.Decimal(10, 2) @default(0)
  discountTotal Decimal            @db.Decimal(10, 2) @default(0)
  total         Decimal            @db.Decimal(10, 2) @default(0)
  pickupAt      DateTime
  dueBackAt     DateTime
  returnedAt    DateTime?
  hasDelay      Boolean            @default(false)
  hasDamage     Boolean            @default(false)
  returnNotes   String?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  customer      Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items         RentalOrderItem[]
  payments      Payment[]
  comprobantes  Comprobante[]
  appointments  Appointment[]
  history       RentalOrderStatusHistory[]
  couponsUsed   OrderCouponUse[]
}

model RentalOrderItem {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rentalOrderId String @db.Uuid
  productId String? @db.Uuid
  rentalUnitId String @db.Uuid
  itemNameSnapshot String
  tierAtRental     RentalPriceTier
  unitPrice        Decimal         @db.Decimal(10, 2)
  returnedAt       DateTime?
  returnCondition  String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  rentalOrder      RentalOrder     @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  rentalUnit       RentalUnit      @relation(fields: [rentalUnitId], references: [id], onDelete: Restrict)
}

model AlterationService {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String
  precioBase  Decimal?          @db.Decimal(10, 2)
  activo      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  orders      AlterationOrder[]
}

model AlterationOrder {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  code               String                 @unique
  status             AlterationOrderStatus  @default(RECIBIDO)
  serviceId String? @db.Uuid
  garmentDescription String
  workDescription    String
  initialCondition   String?
  receivedAt         DateTime
  promisedAt         DateTime?
  deliveredAt        DateTime?
  subtotal           Decimal                @db.Decimal(10, 2) @default(0)
  discountTotal      Decimal                @db.Decimal(10, 2) @default(0)
  total              Decimal                @db.Decimal(10, 2) @default(0)
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  customer           Customer               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service            AlterationService?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  appointments       Appointment[]
  payments           Payment[]
  comprobantes       Comprobante[]
  history            AlterationOrderStatusHistory[]
  couponsUsed        OrderCouponUse[]
}

model Appointment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  code                 String             @unique
  type                 AppointmentType
  status               AppointmentStatus  @default(PENDIENTE)
  scheduledAt          DateTime
  estimatedEndAt       DateTime?
  rescheduleDeadlineAt DateTime?
  cancelDeadlineAt     DateTime?
  confirmedAt          DateTime?
  cancelledAt          DateTime?
  attendedAt           DateTime?
  noShowAt             DateTime?
  reminder24hSentAt    DateTime?
  notes                String?
  internalNotes        String?
  saleOrderId String? @db.Uuid
  customOrderId String? @db.Uuid
  rentalOrderId String? @db.Uuid
  alterationOrderId String? @db.Uuid
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  customer             Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  saleOrder            SaleOrder?         @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)
  customOrder          CustomOrder?       @relation(fields: [customOrderId], references: [id], onDelete: SetNull)
  rentalOrder          RentalOrder?       @relation(fields: [rentalOrderId], references: [id], onDelete: SetNull)
  alterationOrder      AlterationOrder?   @relation(fields: [alterationOrderId], references: [id], onDelete: SetNull)
  history              AppointmentStatusHistory[]
}

model AppointmentStatusHistory {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId String @db.Uuid
  status         AppointmentStatus
  note           String?
  changedAt      DateTime          @default(now())
  changedById String? @db.Uuid

  appointment    Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedBy      AdminUser?        @relation(fields: [changedById], references: [id], onDelete: SetNull)
}

model BusinessHour {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dayOfWeek   Int
  openTime    String?
  closeTime   String?
  isClosed    Boolean  @default(false)
  note        String?

  @@unique([dayOfWeek])
}

model SpecialSchedule {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date        DateTime @db.Date
  openTime    String?
  closeTime   String?
  isClosed    Boolean  @default(false)
  note        String?

  @@unique([date])
}

model Payment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  saleOrderId String? @db.Uuid
  customOrderId String? @db.Uuid
  rentalOrderId String? @db.Uuid
  alterationOrderId String? @db.Uuid
  amount            Decimal          @db.Decimal(10, 2)
  method            PaymentMethod
  concept           PaymentConcept   @default(PAGO_TOTAL)
  status            PaymentStatus    @default(PENDIENTE)
  provider          VoucherProvider?
  operationCode     String?
  approvalCode      String?
  voucherUrl        String?
  paidAt            DateTime         @default(now())
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  saleOrder         SaleOrder?       @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)
  customOrder       CustomOrder?     @relation(fields: [customOrderId], references: [id], onDelete: SetNull)
  rentalOrder       RentalOrder?     @relation(fields: [rentalOrderId], references: [id], onDelete: SetNull)
  alterationOrder   AlterationOrder? @relation(fields: [alterationOrderId], references: [id], onDelete: SetNull)
}

model Comprobante {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String @db.Uuid
  saleOrderId String? @db.Uuid
  customOrderId String? @db.Uuid
  rentalOrderId String? @db.Uuid
  alterationOrderId String? @db.Uuid
  type              ComprobanteType
  status            ComprobanteStatus  @default(BORRADOR)
  serie             String?
  numero            String?
  subtotal          Decimal            @db.Decimal(10, 2) @default(0)
  impuesto          Decimal            @db.Decimal(10, 2) @default(0)
  total             Decimal            @db.Decimal(10, 2) @default(0)
  issuedAt          DateTime?
  pdfUrl            String?
  xmlUrl            String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  saleOrder         SaleOrder?         @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)
  customOrder       CustomOrder?       @relation(fields: [customOrderId], references: [id], onDelete: SetNull)
  rentalOrder       RentalOrder?       @relation(fields: [rentalOrderId], references: [id], onDelete: SetNull)
  alterationOrder   AlterationOrder?   @relation(fields: [alterationOrderId], references: [id], onDelete: SetNull)
}

model ProductStockMovement {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId String @db.Uuid
  type        InventoryMovementType
  quantity    Int
  note        String?
  happenedAt  DateTime             @default(now())

  variant     ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Promotion {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String
  scope         PromotionScope
  discountType  DiscountType
  value         Decimal         @db.Decimal(10, 2)
  startsAt      DateTime
  endsAt        DateTime?
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  coupons       Coupon[]
  productTargets PromotionProductTarget[]
}

model PromotionProductTarget {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promotionId String @db.Uuid
  productId String @db.Uuid
  createdAt   DateTime   @default(now())

  promotion   Promotion  @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([promotionId, productId])
  @@index([productId])
}

model Coupon {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String          @unique
  promotionId String? @db.Uuid
  bundleId String? @db.Uuid
  discountType  DiscountType
  value         Decimal         @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int             @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  promotion     Promotion?      @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  bundle        Bundle?         @relation(fields: [bundleId], references: [id], onDelete: SetNull)
  uses          OrderCouponUse[]
}

model OrderCouponUse {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId String @db.Uuid
  saleOrderId String? @db.Uuid
  customOrderId String? @db.Uuid
  rentalOrderId String? @db.Uuid
  alterationOrderId String? @db.Uuid
  appliedAmount     Decimal           @db.Decimal(10, 2) @default(0)
  createdAt         DateTime          @default(now())

  coupon            Coupon            @relation(fields: [couponId], references: [id], onDelete: Cascade)
  saleOrder         SaleOrder?        @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)
  customOrder       CustomOrder?      @relation(fields: [customOrderId], references: [id], onDelete: SetNull)
  rentalOrder       RentalOrder?      @relation(fields: [rentalOrderId], references: [id], onDelete: SetNull)
  alterationOrder   AlterationOrder?  @relation(fields: [alterationOrderId], references: [id], onDelete: SetNull)
}

model Notification {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String? @db.Uuid
  channel      NotificationChannel
  status       NotificationStatus  @default(PENDIENTE)
  subject      String?
  message      String
  sentAt       DateTime?
  relatedCode  String?
  createdAt    DateTime            @default(now())

  customer     Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model SaleOrderStatusHistory {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleOrderId String @db.Uuid
  status       SaleOrderStatus
  note         String?
  changedAt    DateTime         @default(now())
  changedById String? @db.Uuid

  saleOrder    SaleOrder        @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  changedBy    AdminUser?       @relation(fields: [changedById], references: [id], onDelete: SetNull)
}

model CustomOrderStatusHistory {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customOrderId String @db.Uuid
  status        CustomOrderStatus
  note          String?
  changedAt     DateTime           @default(now())
  changedById String? @db.Uuid

  customOrder   CustomOrder        @relation(fields: [customOrderId], references: [id], onDelete: Cascade)
  changedBy     AdminUser?         @relation(fields: [changedById], references: [id], onDelete: SetNull)
}

model RentalOrderStatusHistory {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rentalOrderId String @db.Uuid
  status        RentalOrderStatus
  note          String?
  changedAt     DateTime           @default(now())
  changedById String? @db.Uuid

  rentalOrder   RentalOrder        @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  changedBy     AdminUser?         @relation(fields: [changedById], references: [id], onDelete: SetNull)
}

model AlterationOrderStatusHistory {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alterationOrderId String @db.Uuid
  status            AlterationOrderStatus
  note              String?
  changedAt         DateTime              @default(now())
  changedById String? @db.Uuid

  alterationOrder   AlterationOrder       @relation(fields: [alterationOrderId], references: [id], onDelete: Cascade)
  changedBy         AdminUser?            @relation(fields: [changedById], references: [id], onDelete: SetNull)
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  adminProfile  AdminUser? @relation("AdminAuthUser")
  customer      Customer?  @relation("CustomerAuthUser")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}
